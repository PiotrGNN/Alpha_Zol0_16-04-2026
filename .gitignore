# Clean push allowlist
/*

# Root metadata kept in the initial source-of-truth push
!/.gitignore
!/.flake8
!/pytest.ini
!/README.md
!/PROJECT_OVERVIEW.md
!/RUNBOOK.md

# CI: keep Python CI only; docker smoke depends on excluded compose files
!/.github/
/.github/*
!/.github/workflows/
/.github/workflows/*
!/.github/workflows/python-ci.yml

# Source-of-truth project lives in the nested project directory
!/Alpha_Zol0-lvl_5-main/
