# ---------------------------------------------------------------------------
# LIVE ARMING (ALL REQUIRED — six conditions must be true simultaneously)
# ---------------------------------------------------------------------------
LIVE=1
LIVE_ARMED=1
LIVE_APPROVAL=I_UNDERSTAND_LIVE_RISK

# ---------------------------------------------------------------------------
# SYMBOL RESTRICTION — ETHUSDTM only (Phase 1 guarded rollout)
# ---------------------------------------------------------------------------
ENTRY_SYMBOL_STRATEGY_SIDE_ALLOWLIST=ETHUSDTM:MOMENTUM:buy

# ---------------------------------------------------------------------------
# KNOWN PARAMETER FIX (documented 2026-04-20 in DECISIONS_LOG + RUNBOOK)
# Default EXIT_CLOSE_ATTEMPT_FEE_GUARD_COOLDOWN_SEC=300 suppresses
# post-green protective exit for 5 minutes. Override to 10s for this rollout.
# ---------------------------------------------------------------------------
EXIT_CLOSE_ATTEMPT_FEE_GUARD_COOLDOWN_SEC=10

# ---------------------------------------------------------------------------
# HARD STOP THRESHOLDS (read by scripts/live_rollout_monitor.py)
# ---------------------------------------------------------------------------
# Abnormal exit delay: post_green_bnr_time_forced_exit_sec > threshold triggers HARD STOP
LIVE_ROLLOUT_ABNORMAL_EXIT_DELAY_SEC=120
# Consecutive losses: N consecutive losing trades triggers HARD STOP
LIVE_ROLLOUT_MAX_CONSECUTIVE_LOSSES=3
# Max portfolio drawdown (fraction): triggers HARD STOP
LIVE_ROLLOUT_MAX_DRAWDOWN_PCT=0.02

# ---------------------------------------------------------------------------
# MILESTONE TARGETS (informational — not hard stops)
# ---------------------------------------------------------------------------
# Monitor logs MILESTONE when this many closed trades are reached
LIVE_ROLLOUT_TARGET_CLOSED_TRADES=30

