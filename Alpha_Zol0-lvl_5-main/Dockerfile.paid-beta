FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app
COPY requirements-paid-beta.txt ./
RUN pip install --no-cache-dir -r requirements-paid-beta.txt
COPY alembic.ini ./
COPY paid_beta ./paid_beta
RUN mkdir -p /app/analysis
EXPOSE 8000
CMD ["sh", "-c", "alembic upgrade head && uvicorn paid_beta.app:app --host 0.0.0.0 --port 8000"]
