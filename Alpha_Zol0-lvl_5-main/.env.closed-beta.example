# Copy to a secret-managed staging environment. Do not commit populated values.
PAID_BETA_ENV=production
PAID_BETA_DATABASE_URL=
PAID_BETA_RESTORE_DATABASE_URL=
PAID_BETA_TOKEN_SECRET=
PAID_BETA_APP_URL=https://beta.example.com
PAID_BETA_CORS_ORIGINS=https://beta.example.com
PAID_BETA_ALLOW_ADMIN_BOOTSTRAP=0
PAID_BETA_EXPOSE_PASSWORD_RESET_TOKEN=0
PAID_BETA_TRADING_SCORECARD_PATH=/app/analysis/zol0_profitability_audit_scorecard.json

# Keep false until the final documents are completed and legally approved.
PAID_BETA_TERMS_APPROVED=0
PAID_BETA_PRIVACY_APPROVED=0
PAID_BETA_REFUNDS_APPROVED=0
PAID_BETA_RISK_DISCLOSURE_APPROVED=0

# Stripe TEST mode only during rehearsal.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_REPORT=

# SMTP staging account.
PAID_BETA_SMTP_HOST=
PAID_BETA_SMTP_PORT=587
PAID_BETA_SMTP_USERNAME=
PAID_BETA_SMTP_PASSWORD=
PAID_BETA_SMTP_FROM=
PAID_BETA_SMTP_STARTTLS=1

# Set only in the operator shell for a single economics import.
PAID_BETA_ADMIN_TOKEN=

# Explicit opt-in required by the guarded restore rehearsal.
PAID_BETA_STAGING_REHEARSAL=0
